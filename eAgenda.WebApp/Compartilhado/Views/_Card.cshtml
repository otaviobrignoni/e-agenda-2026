@model (DisplayFieldViewModel titulo, DisplayFieldViewModel[] campos, Guid id, bool mostrarDetalhes, bool mostrarExcluir)
<div class="col-12 col-md-6 col-xl-4">
    <div class="card h-100 shadow-sm border-1 rounded-4">
        <div class="card-body d-flex flex-column">
            <partial name="_CardTitulo" model="@Model.titulo" />

            <partial name="_CardCampos" model="@Model.campos" />

            <partial name="_CardAcoes" model="(Model.id, Model.mostrarDetalhes, Model.mostrarExcluir)" />
        </div>
    </div>
</div>
