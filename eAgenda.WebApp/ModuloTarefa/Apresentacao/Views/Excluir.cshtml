@{
    ViewBag.Titulo = "Exclusão de Tarefa";

    var percentualConcluido = Math.Clamp(Model.PercentualConcluido * 100, 0, 100);
    var campos = new[]
    {
        Model.DisplayField(vm => vm.Id, "ID"),
        Model.DisplayField(vm => vm.Titulo, "Título"),
        Model.DisplayField(vm => vm.Prioridade),
        Model.DisplayField(vm => vm.DataCriacao, Model.DataCriacao.ToShortDateString(), "Data de Criação"),
        Model.DisplayField(vm => vm.DataConclusao, Model.DataConclusao?.ToShortDateString() ?? "Pendente", "Data de Conclusão"),
        Model.DisplayField(vm => vm.PercentualConcluido, $"{percentualConcluido:0}%", "Progresso")
    };
}

@model MostrarTarefaViewModel

<form class="card border-primary-subtle shadow-sm mx-auto p-4" style="max-width: 620px;" asp-action="Excluir" asp-route-id="@Model.Id" method="post">
    <partial name="_Alerta" model="@(new AlertaViewModel("Tem certeza que deseja excluir esta tarefa?"))" />
    <partial name="_CardCampos" model="@campos" />
    <partial name="_FormAcoes" />
</form>
