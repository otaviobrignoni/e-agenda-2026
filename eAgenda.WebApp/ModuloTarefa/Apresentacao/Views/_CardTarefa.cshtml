@model MostrarTarefaViewModel

@{
    var percentualConcluido = Math.Clamp(Model.PercentualConcluido * 100, 0, 100);
}

<div class="col-12 col-md-6 col-xl-4" data-tarefa-card data-prioridade="@((int)Model.Prioridade)" data-status="@(Model.EstaConcluida ? "Concluida" : "Pendente")">
    <div class="card h-100 shadow-sm border-1 rounded-4">
        <div class="card-body d-flex flex-column">
            <div class="d-flex justify-content-between align-items-start mb-2">
                <h5 class="card-title mb-0">@Model.Titulo</h5>
                <span class="badge rounded-pill @Model.ClassePrioridade">
                    @Model.Prioridade
                </span>
            </div>
            <p class="text-muted small mb-3"> Criada em @Model.DataCriacao.ToShortDateString() </p>
            <div class="mb-3">
                <div class="d-flex justify-content-between small mb-1">
                    <span>
                        Progresso @if (Model.EstaConcluida && Model.DataConclusao is not null)
                        {
                            <span class="text-muted small text-start"> Concluida em @Model.DataConclusao.Value.ToShortDateString() </span>
                        }
                    </span>
                    <span>@percentualConcluido.ToString("0", CultureInfo.CurrentCulture)%</span>
                </div>
                <div class="progress" style="height: 8px;">
                    <div class="progress-bar" role="progressbar" style="width: @percentualConcluido.ToString("0.##", CultureInfo.InvariantCulture)%" aria-valuenow="@percentualConcluido.ToString("0.##", CultureInfo.InvariantCulture)" aria-valuemin="0" aria-valuemax="100"> </div>
                </div>
            </div>
            <partial name="_CardAcoes" model="(Model.Id, true, true)" />
        </div>
    </div>
</div>
