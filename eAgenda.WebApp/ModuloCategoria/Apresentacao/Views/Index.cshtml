@{
    ViewBag.Titulo = "Listagem de Categorias";
}

@model List<CategoriaViewModel>;

<partial name="_BotaoCadastrar" model="false" />

@if (TempData["MensagemErro"] is string mensagemErro)
{
    <partial name="_Alerta" model="@new AlertaViewModel(mensagemErro, true)" />
}
@if (Model.Count == 0)
{
    <partial name="_Alerta" model="@(new AlertaViewModel("Nenhuma Categoria cadastrada."))" />
}
else
{
    <div class="row row-cols-1 row-cols-md-2 row-cols-xl-3 g-2">
        @foreach (var c in Model)
        {
            var campos = new[] {
                c.DisplayField(vm => vm.Titulo)
            };
            <partial name="_Card" model="(c.DisplayField(vm => vm.Id.ToShortString(), c.Titulo), campos, c.Id, false, true)" />
        }
    </div>
}
